{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm verify && pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/ingest",
      "schedule": "0 7 * * *"
    }
  ]
}
