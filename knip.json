{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "data/**/*.ts",
    "lib/**/*.ts",
    "lhci.config.cjs",
    "scripts/*.mjs",
    "tests/**/*.ts"
  ],
  "project": ["**/*.{ts,tsx,js,jsx,mjs,cjs}"],
  "ignoreDependencies": ["@lhci/cli", "lighthouse", "tailwindcss", "three"],
  "ignoreIssues": {
    "data/trade.ts": ["duplicates"]
  },
  "ignoreExportsUsedInFile": true
}
