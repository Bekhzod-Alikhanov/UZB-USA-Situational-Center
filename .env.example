# =============================================================================
# UZ–US Situational Center · environment template
#
# Copy this file to `.env.local` for development:
#     cp .env.example .env.local
#
# In Vercel, set these as project Environment Variables (Production + Preview).
# =============================================================================

# -------------------------------------------------------------------
# Admin gate
# -------------------------------------------------------------------
# Password required to enter /[locale]/admin. No default is provided; the admin
# area remains inaccessible until this is configured.
ADMIN_PASSWORD=

# Optional but strongly recommended in production. Used to sign the short-lived
# admin session cookie. If unset, ADMIN_PASSWORD is used as the signing secret.
ADMIN_SESSION_SECRET=

# Stage-2 hokimiyat editor passwords (optional). Each unlocks the same login
# form with a region-scoped role: the holder can mark roadmap tasks done /
# leave notes for their region and upload visit materials on /prepare, but
# cannot enter /admin. Leave blank to keep the gate admin-only.
REGION_PASSWORD_SAMARKAND=
REGION_PASSWORD_KHOREZM=

# -------------------------------------------------------------------
# Live public data and operational database (optional)
# -------------------------------------------------------------------
# Static mode keeps the dashboard fully deployable from bundled data/*.ts.
# Use supabase only after provisioning a private project, RLS, backups, and
# an audit model for operational records.
DATA_BACKEND=static
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required before Vercel scheduled ingestion can write snapshots/review items.
# Vercel sends this as Authorization: Bearer <CRON_SECRET> for cron jobs.
CRON_SECRET=

# Optional rate-limit key for the U.S. Census international trade API.
CENSUS_API_KEY=

# Optional official-data keys. Leave blank until the source mapping is approved.
BEA_API_KEY=
DATA_GOV_API_KEY=

# Optional: override the Census month used by scheduled ingestion. Format YYYY-MM.
CENSUS_INGEST_MONTH=

# -------------------------------------------------------------------
# Node / Next runtime (optional, usually auto-detected)
# -------------------------------------------------------------------
# NODE_ENV=production
