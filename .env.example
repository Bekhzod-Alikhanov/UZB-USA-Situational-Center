# =============================================================================
# UZ–US Situational Center · environment template
#
# Copy this file to `.env.local` for development:
#     cp .env.example .env.local
#
# In Vercel, set these as project Environment Variables (Production + Preview).
# =============================================================================

# -------------------------------------------------------------------
# Admin gate
# -------------------------------------------------------------------
# Password required to enter /[locale]/admin. Defaults to "uzus2026" in dev
# if unset; ROTATE THIS BEFORE PRODUCTION.
ADMIN_PASSWORD=

# -------------------------------------------------------------------
# AI assistant (optional)
# -------------------------------------------------------------------
# When set, /api/chat streams responses from Anthropic. When unset, the
# /assistant page shows a graceful "AI disabled — set ANTHROPIC_API_KEY" state
# and the route returns 503.
#
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# -------------------------------------------------------------------
# Node / Next runtime (optional, usually auto-detected)
# -------------------------------------------------------------------
# NODE_ENV=production
