    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "knip": "^6.22.0",
    "lighthouse": "^13.4.0",
    "postcss": "^8.5.15",
    "prettier": "^3.9.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
